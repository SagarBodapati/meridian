# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (financial embeddings)
VOYAGE_API_KEY=pa-...

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=meridian-financial
PINECONE_ENVIRONMENT=us-east-1-aws

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=meridian-chunks

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (metric store)
DATABASE_URL=postgresql://meridian:meridian@localhost:5432/meridian

# SEC EDGAR
EDGAR_USER_AGENT=Meridian Research contact@meridian.ai
EDGAR_REQUEST_DELAY=0.1

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Model routing
MODEL_SIMPLE=claude-haiku-4-5-20251001
MODEL_STANDARD=claude-sonnet-4-6
MODEL_COMPLEX=claude-opus-4-7
